# Required for AI analysis (or use the BYOK input in the UI)
ANTHROPIC_API_KEY=

# Auth (set all of these to enable login/signup features)
NEXT_PUBLIC_AUTH_ENABLED=true
NEXTAUTH_SECRET=             # Generate: openssl rand -base64 32
NEXTAUTH_URL=https://your-app.vercel.app
DATABASE_URL=file:./dev.db  # For production: postgresql://user:password@host:5432/dbname

# OAuth providers (optional - only needed if you want Google/GitHub login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=
